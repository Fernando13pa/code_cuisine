<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /KochBuchCuisine/

  # Serve real files/directories (js, css, svg, images...) as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else is an Angular route: let the SPA's router handle it.
  RewriteRule ^ index.html [L]
</IfModule>
